# Copy to .env and fill in real values.
# openssl rand -hex 32  → use output for ENCRYPTION_KEY

DATABASE_URL="postgresql://user:pass@localhost:5432/vaultbox"
JWT_SECRET="replace-with-a-long-random-string-at-least-32-chars"
ENCRYPTION_KEY="64-char-hex-from-openssl-rand-hex-32"
ETH_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY"
SOL_RPC_URL="https://api.devnet.solana.com"
BTC_API_URL="https://blockstream.info/testnet/api"

# Etherscan API key — REQUIRED for Ethereum transaction history sync.
# Etherscan deprecated their V1 API in August 2025; the V2 API requires a key.
# Without this, inbound ETH/ERC-20 transfers will not appear in transaction history.
# Get a free key: https://etherscan.io/apidashboard
ETHERSCAN_API_KEY=""

# App URL (used in verification emails)
APP_URL="http://localhost:3000"

# SMTP (optional — if not set, verification emails log to console)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"
