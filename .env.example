# Copy to .env and fill in real values.
# openssl rand -hex 32  → use output for ENCRYPTION_KEY

DATABASE_URL="postgresql://user:pass@localhost:5432/vaultbox"
JWT_SECRET="replace-with-a-long-random-string-at-least-32-chars"
ENCRYPTION_KEY="64-char-hex-from-openssl-rand-hex-32"
ETH_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY"
SOL_RPC_URL="https://api.devnet.solana.com"
BTC_API_URL="https://blockstream.info/testnet/api"

# Etherscan API key — REQUIRED for Ethereum transaction history sync.
# Etherscan deprecated their V1 API in August 2025; the V2 API requires a key.
# Without this, inbound ETH/ERC-20 transfers will not appear in transaction history.
# Get a free key: https://etherscan.io/apidashboard
ETHERSCAN_API_KEY=""

# App URL (used in verification emails)
APP_URL="http://localhost:3000"

# SMTP (optional — if not set, verification emails log to console)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# SoftHSM (optional — when set, private key encryption is handled by the SoftHSM
# instead of using ENCRYPTION_KEY directly. Run `make softhsm-init` to generate the keystore.)
# SOFTHSM_MASTER_PASSWORD="strong-password-at-least-8-chars"
# SOFTHSM_KEYSTORE_PATH="./softhsm-keystore.enc"
# SOFTHSM_KEY_ID="softhsm-master"
# SOFTHSM_AUDIT_LOG_PATH="./softhsm-audit.jsonl"
# SOFTHSM_BACKUP_DIR="./softhsm-backups"
# SOFTHSM_CALLER_SECRET="hex-secret-for-caller-auth"
# SOFTHSM_RATE_LIMIT="100"
# SOFTHSM_RATE_WINDOW_MS="60000"
# SOFTHSM_SESSION_TIMEOUT_MS="300000"
# SOFTHSM_AUDIT_WEBHOOK="https://your-siem.example.com/webhook"
# SOFTHSM_AUDIT_HMAC_KEY="hex-key-for-audit-chain"
# SOFTHSM_SOCKET_PATH="/tmp/softhsm.sock"
# SOFTHSM_FIPS="1"  (enable FIPS mode — requires OpenSSL 3.x FIPS provider)
# SOFTHSM_SHARES='{"index":1,"data":"..."}'  (comma-separated JSON for M-of-N unlock)
